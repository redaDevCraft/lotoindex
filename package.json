{
    "name": "lotoindex",
    "version": "1.0.0",
    "description": "Gestion de véhicules - LotoIndex",
    "main": "electron/main.js",
    "author": "redaDevCraft",
    "scripts": {
        "dev:renderer": "vite",
        "dev:electron": "electron .",
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
        "build:renderer": "vite build",
        "dist": "npm run build:renderer && electron-builder",
        "dist:win": "npm run build:renderer && electron-builder --win",
        "dist:mac": "npm run build:renderer && electron-builder --mac",
        "dist:linux": "npm run build:renderer && electron-builder --linux"
    },
    "build": {
        "appId": "com.redadevcraft.lotoindex",
        "productName": "LotoIndex",
        "directories": {
            "output": "dist-app"
        },
        "files": [
            "electron/**/*",
            "database/**/*",
            "renderer/dist/**/*",
            "index.html",
            "package.json"
        ],
        "extraResources": [{
            "from": "database/",
            "to": "database/",
            "filter": [
                "**/*"
            ]
        }],
        "win": {
            "target": [{
                "target": "nsis",
                "arch": [
                    "x64"
                ]
            }],
            "icon": "assets/icon.ico"
        },

        "linux": {
            "target": "AppImage",
            "icon": "assets/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "installerLanguages": [
                "fr_FR",
                "en_US"
            ]
        }
    },
    "dependencies": {
        "exceljs": "^4.4.0",
        "fuse.js": "^7.0.0",
        "papaparse": "^5.4.1",
        "pdfkit": "^0.15.0",
        "sqlite3": "^5.1.7"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^9.2.1",
        "electron": "^31.0.0",
        "electron-builder": "^26.8.1",
        "electron-rebuild": "^3.2.9",
        "wait-on": "^8.0.1"
    }
}